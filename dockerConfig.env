# Docker Compose 环境变量配置

# PostgreSQL 数据库
POSTGRES_DB=fastshow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Redis 缓存
REDIS_PASSWORD=your_redis_password_here

# MinIO 对象存储
MINIO_USER=minioadmin
MINIO_PASSWORD=your_minio_password_here

# Coturn (WebRTC 穿透服务器)
COTURN_REALM=your_domain.com
COTURN_USER=fastshow
COTURN_PASSWORD=your_coturn_password_here
COTURN_EXTERNAL_IP=your_server_ip
